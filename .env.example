GEMINI_API_KEY=your_gemini_api_key_here

# Opsional — API key terpisah untuk embedding (gemini-embedding-001).
# Jika tidak di-set, fallback ke GEMINI_API_KEY.
# Pisahkan agar kuota generation tidak terganggu kuota embedding.
# EMBEDDING_API_KEY=your_embedding_api_key_here

# URL Qdrant — default localhost untuk development.
# Di production (Railway/Render), isi dengan URL Qdrant Cloud atau service Qdrant kamu.
# QDRANT_URL=http://localhost:6333

# Opsional — API key untuk Qdrant Cloud. Kosongkan untuk Qdrant lokal (tanpa auth).
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# Opsional — origins yang diizinkan akses API, dipisah koma.
# Default jika tidak di-set: http://localhost:3000,http://localhost:8501
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Opsional — API key untuk endpoint /add. Jika di-set, request ke /add harus
# menyertakan header: X-Api-Key: <nilai ini>. Kosongkan untuk disable.
# ADD_API_KEY=rahasia123
